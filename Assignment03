#include <bits/stdc++.h>
using namespace std;
int main(){
	int n;
	cin>>n;
	int arr[n];
	for(int i=0;i<n;i++){
		cin>>arr[i];
	}
	stack<int> st;
	vector<int> ans(n);
	for(int i=0;i<n;i++){

		 while (!st.empty() && arr[st.top()] <= arr[i]) {
            st.pop();
        }

       
        if (st.empty()) {
            ans[i] = (i + 1);
        }
        else {
            ans[i] = (i - st.top());
        }
		st.push(i);


	}
	for(int i=0;i<n;i++){
		cout<<ans[i]<<" ";
	}
	return 0;
}
