#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
    int t;
    cin>>t;
    while(t--){
        int n,m;
        cin>>n>>m;
        string a;
        cin>>a;
        string b;
        cin>>b;
        string ans="";
        int j=min(n,m);
        for(int i=0;i<j;i++){
            if(a[i]!=b[i]){
                break;
            }
            ans=ans+a[i];
        }
        cout<<ans<<endl;
        
    }
    return 0;
}
